{
  "schema_version": "1.0",
  "agent": {
    "name": "cnbe-hanzi-structure-encoding-agent",
    "portable_skill": "skill/cnbe-hanzi-structure-encoding-agent/SKILL.md",
    "github_profile": ".github/agents/cnbe-hanzi-structure-encoding-agent.agent.md"
  },
  "run_contract": {
    "run_id": "cnbe-agent-run-YYYYMMDD-HHMMSS",
    "operator_role": "repository-executor",
    "input_scope": "declare exact row range, character list, or file list before execution",
    "input_artifacts": [
      "path/to/input.csv",
      "path/to/evidence.json"
    ],
    "unicode_gate": {
      "required": true,
      "checks": [
        "character literal matches declared Unicode code point",
        "code point is stable before structure work",
        "compatibility or variant ambiguity is reported before scoring"
      ]
    },
    "authority_order": [
      "national-language-writing-standards",
      "8105-core-baseline",
      "repository-reviewed-knowledge-assets",
      "dictionary-and-character-origin-context",
      "network-context",
      "historical-ai-generated-cnbe-fields"
    ],
    "allowed_outputs": [
      "planning report",
      "read-only audit report",
      "review packet",
      "candidate mapping table",
      "checkpoint file",
      "test-only validation artifact"
    ],
    "forbidden_outputs": [
      "unapproved runtime database rewrite",
      "unapproved source catalog rewrite",
      "unapproved tag",
      "unapproved GitHub release",
      "unapproved PyPI publish",
      "claiming 97,686-row validation from a partial run",
      "promoting dictionary or network context as national-standard authority"
    ],
    "stop_conditions": [
      "Unicode identity mismatch",
      "unknown or non-approved structure label",
      "missing 8105 alignment for release-track row",
      "mixed authority grades without explicit labels",
      "GF0017 normativity blocker",
      "missing evidence for promoted output",
      "attempted write outside declared allowed outputs"
    ],
    "verification_commands": [
      "python scripts/validate_format_integrity.py",
      "python scripts/validate_doc_version.py",
      "python -m compileall src tests scripts",
      "python -m pytest tests/test_repository_published_agent_skill.py -q",
      "python -m ruff check src tests scripts"
    ],
    "review_required_before": [
      "database rebuild",
      "runtime JSON overwrite",
      "source table overwrite",
      "release branch merge",
      "tag creation",
      "GitHub release",
      "PyPI publication"
    ],
    "resume_policy": {
      "checkpoint_required": true,
      "resume_from_failed_row_only_after_review": true,
      "preserve_original_artifacts_by_path_and_checksum": true
    }
  }
}

